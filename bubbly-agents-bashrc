# bubbly-agents shell configuration
# Source this file from ~/.bashrc:
#   echo 'source ~/bubbly-agents/bubbly-agents-bashrc' >> ~/.bashrc

# Start in project directory
cd ~/bubbly-agents 2>/dev/null || true

# Homebrew
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

# direnv (auto-activates .venv when entering the project directory)
eval "$(direnv hook bash)"

# Show active venv in prompt when direnv is managing it
show_virtual_env() {
  if [[ -n "$VIRTUAL_ENV" && -n "$DIRENV_DIR" ]]; then
    echo "($(basename $VIRTUAL_ENV))"
  fi
}
export -f show_virtual_env
PS1='$(show_virtual_env)'$PS1

# tmux session check — runs once on the first prompt so the shell is
# fully interactive before tmux starts; detaching returns to the prompt.
_bubbly_tmux_check_done=0
_bubbly_tmux_check() {
    [[ $_bubbly_tmux_check_done -eq 1 ]] && return
    _bubbly_tmux_check_done=1
    [[ -n "${TMUX}" ]] && return
    command -v tmux >/dev/null 2>&1 || return

    local _sessions _count _name _reply
    _sessions=$(tmux ls 2>/dev/null) || true
    if [[ -n "${_sessions}" ]]; then
        echo ""
        echo "Running tmux sessions:"
        echo "${_sessions}"
        echo ""
        _count=$(echo "${_sessions}" | wc -l)
        if [[ ${_count} -eq 1 ]]; then
            _name=$(echo "${_sessions}" | cut -d: -f1)
            read -r -p "Attach to '${_name}'? [Y/n]: " _reply
            [[ "${_reply,,}" != "n" ]] && tmux attach -t "${_name}"
        else
            read -r -p "Attach to session (name, or Enter to skip): " _reply
            [[ -n "${_reply}" ]] && tmux attach -t "${_reply}"
        fi
    else
        read -r -p "No tmux sessions running. Start one? [Y/n]: " _reply
        [[ "${_reply,,}" != "n" ]] && tmux new-session -s sandboxes
    fi
}
PROMPT_COMMAND="_bubbly_tmux_check${PROMPT_COMMAND:+; ${PROMPT_COMMAND}}"
